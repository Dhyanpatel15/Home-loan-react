# Email notification - optional
RESEND_API_KEY=
LEAD_EMAIL_TO=your-email@gmail.com
LEAD_EMAIL_FROM=LoanHub <onboarding@resend.dev>

# Future API / CRM webhook - optional
LEAD_WEBHOOK_URL=
LEAD_WEBHOOK_TOKEN=

# Production database for Vercel - recommended
# Create the Supabase table using supabase_loan_leads.sql, then add these ENV variables in Vercel.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_LEADS_TABLE=loan_leads
